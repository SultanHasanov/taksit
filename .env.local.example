# Copy this file to .env.local and fill in your Firebase project credentials
# Get them from: Firebase Console → Project Settings → Your Apps → Web App → SDK snippet

VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# DaData API token (for address autocomplete)
# Get free token at: https://dadata.ru/api/suggest/
VITE_DADATA_TOKEN=a17c1b8db5c44bf264bf804062ffe577594171e5
